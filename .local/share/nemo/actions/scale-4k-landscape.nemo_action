[Nemo Action]
Name=Scale to 4K Landscape…
Comment=Scale image down to fit within 3840x2160, keeping aspect ratio
Exec=bash -c 'for f in %F; do base="${f%.*}"; convert "$f" -resize "3840x2160>" "${base}_4k_landscape.jpg"; done'
Icon-Name=image-x-generic
Selection=any
Extensions=jpg;jpeg;png;gif;bmp;tiff;webp;
